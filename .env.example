# =============================================================================
# Viralytics — .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
PROJECT_NAME="Viralytics"
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# API key that protects all /api/v1 read endpoints and admin endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secret-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/viralytics

# ── Redis (local dev queue backend) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
QUEUE_BACKEND=redis   # "redis" | "sqs"

# ── Amazon SQS (production queue backend) ────────────────────────────────────
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/viralytics-scrape-jobs
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Scraper ───────────────────────────────────────────────────────────────────
# How many concurrent scraper workers to run
MAX_SCRAPER_WORKERS=3
# Random delay range between requests (seconds) — keeps traffic human-like
SCRAPE_DELAY_MIN_S=2.0
SCRAPE_DELAY_MAX_S=6.0
# Per-request timeout (seconds)
SCRAPER_TIMEOUT_S=30
# Maximum retry attempts before marking job as dead
SCRAPER_MAX_RETRIES=3
# Maximum posts to collect per scrape run (per influencer)
MAX_POSTS_PER_SCRAPE=50
# Playwright headless mode (used by the login automator, scripts/register_instagram_account.py)
SCRAPER_HEADLESS=true

# ── Instagram Account Pool ───────────────────────────────────────────────────
# Accounts are no longer configured here. Register one (or several) via:
#   uv run python scripts/register_instagram_account.py --username your_scraper_account
# which logs in with Playwright and stores the resulting session in the
# instagram_accounts table (see app/models/instagram_account.py).
#
# Fernet key used to encrypt session cookies at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ACCOUNT_ENCRYPTION_KEY="8y8rhGawiSDQGc7KynEWIqybVD2FstQoL58NHAFtlXI="
# How long a worker may hold an account before its lease is considered stale
# and reclaimed (seconds).
ACCOUNT_LEASE_TIMEOUT_S=1800
# Consecutive failures before an account is auto-disabled.
ACCOUNT_MAX_CONSECUTIVE_FAILURES=5

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
# Override cron expressions if needed (cron syntax: minute hour dom month dow)
CRON_PROFILE_UPDATE="0 2 * * *"
CRON_POST_DISCOVERY="0 */4 * * *"
CRON_FEATURE_EXTRACTION="30 */4 * * *"
CRON_ANALYTICS="0 4 * * *"
CRON_BENCHMARK="0 5 * * *"
CRON_RECOMMENDATION="0 6 * * *"
CRON_CLEANUP="0 3 * * 0"
CRON_RETRY_FAILED="0 * * * *"
